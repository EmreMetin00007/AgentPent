# AgentPent environment variables

# OpenRouter API key and base URL
AGENTPENT_OPENAI_API_KEY=your-api-key-here
AGENTPENT_OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Models
AGENTPENT_DEFAULT_MODEL=openai/gpt-5.4
AGENTPENT_PLANNING_MODEL=anthropic/claude-sonnet-4.6
AGENTPENT_THINKING_MODEL=qwen/qwen3-max-thinking
AGENTPENT_TEMPERATURE=0.2
AGENTPENT_MAX_TOKENS=4096

# Database
# AGENTPENT_DB_PATH=./data/agentpent.db

# Scope
# AGENTPENT_SCOPES_FILE=./config/scopes.yaml
AGENTPENT_REQUIRE_SCOPE=true

# Logging
AGENTPENT_LOG_LEVEL=INFO
# AGENTPENT_LOG_DIR=./logs

# Reports
# AGENTPENT_REPORTS_DIR=./reports/output

# Safety
AGENTPENT_MAX_CONCURRENT_TOOLS=5
AGENTPENT_RATE_LIMIT_RPS=10.0
