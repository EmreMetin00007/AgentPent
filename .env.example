# AgentPent environment variables
#
# Leave values blank to use the application's built-in defaults.
# The OpenRouter API key should be filled before running live LLM workflows.

# OpenRouter API
AGENTPENT_OPENAI_API_KEY=
AGENTPENT_OPENAI_BASE_URL=

# Models
AGENTPENT_DEFAULT_MODEL=
AGENTPENT_PLANNING_MODEL=
AGENTPENT_THINKING_MODEL=
AGENTPENT_TEMPERATURE=
AGENTPENT_MAX_TOKENS=

# Database
AGENTPENT_DB_PATH=

# Scope
AGENTPENT_SCOPES_FILE=
AGENTPENT_REQUIRE_SCOPE=

# Logging
AGENTPENT_LOG_LEVEL=
AGENTPENT_LOG_DIR=

# Reports
AGENTPENT_REPORTS_DIR=

# Safety
AGENTPENT_MAX_CONCURRENT_TOOLS=
AGENTPENT_RATE_LIMIT_RPS=
